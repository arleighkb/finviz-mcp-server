[flake8]
max-line-length = 88
# E203: whitespace before ':' (conflicts with black)
# W503: line break before binary operator (conflicts with black)
# E501: line too long (handled by black)
extend-ignore = E203, W503, E501
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    build,
    dist,
    *.egg-info,
    .mypy_cache,
    .pytest_cache,
    articles,
    reports,
    docs
per-file-ignores =
    # Allow unused imports in __init__.py files
    __init__.py:F401
    # Tests can use longer lines and may have unused imports for fixtures
    tests/*:F401,F811
